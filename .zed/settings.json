{
    "disable_ai": true,
    "format_on_save": "on",
    "project_name": "cyberdrop-dl",
    "languages": {
        "Python": {
            "show_whitespaces": "all",
            "show_edit_predictions": true,
            "hard_tabs": false,
            "format_on_save": "on",
            "formatter": {
                "language_server": {
                    "name": "ruff"
                }
            },
            "language_servers": ["ruff", "basedpyright"]
        }
    },
    "lsp": {
        "basedpyright": {
            "settings": {
                "python": {
                    "pythonPath": ".venv/bin/python"
                },
                "basedpyright.analysis": {
                    "diagnosticMode": "openFilesOnly"
                }
            }
        }
    },
    "file_scan_exclusions": [
        "**/.git",
        "**/.vscode",
        "**/.venv",
        "**/.ruff_cache",
        "**/.pytest_cache",
        "**/.tox"
    ]
}
